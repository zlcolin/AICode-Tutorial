# 数据库环境配置
NODE_ENV=production

# 数据库配置
DB_DIALECT=sqlite
DB_STORAGE=./psystem.sqlite
DB_NAME=psystem
DB_USER=PS01
DB_PASSWORD=PS01PWD
DB_HOST=192.168.229.26
DB_PORT=3306

# 数据库连接池配置
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# 其他环境变量
PORT=3000
JWT_SECRET=your_jwt_secret
API_VERSION=v1